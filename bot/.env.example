# ── Discord ─────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_client_id
# GUILD_ID=your_test_guild_id   # Uncomment for fast guild-scoped command registration during dev

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vca:vca_password@localhost:5432/vibe_code_arena
DATABASE_SSL=false   # Set to true on managed DB services (Render, Railway, etc.)

# ── Anthropic (LLM scoring) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Scoring Microservice ──────────────────────────────────────────────────────
SCORING_SERVICE_URL=http://localhost:3001
SCORING_SERVICE_PORT=3001

# ── Debug ─────────────────────────────────────────────────────────────────────
LOG_QUERIES=false   # Set to true to log all SQL queries
